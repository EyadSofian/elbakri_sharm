# Canonical site URL — used for metadata, OG tags, robots.txt and sitemap.xml.
# Set this to the production domain in the hosting provider's env settings.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# --- Analytics (public IDs; defaults match the production ELBAKRI accounts) ---
NEXT_PUBLIC_META_PIXEL_ID=1015996327481578
NEXT_PUBLIC_CLARITY_ID=xg5ape30fv
NEXT_PUBLIC_GTM_ID=GTM-P7BRD5HC

# --- Supabase (enables the DB-backed catalog + hidden admin CMS) ---
# Leave ALL THREE unset to run on the static seed catalog (no admin).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser. Used for seeding + admin bootstrap.
SUPABASE_SERVICE_ROLE_KEY=

# --- Playwright authenticated-admin e2e (optional) ---
# A seeded, active admin account used only by e2e/admin.spec.ts.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# --- EasyKash online payments (server-only; leave unset to keep checkout hidden) ---
# Rotate the key shown in the dashboard, then paste the NEW one here. Never commit real values.
EASYKASH_API_KEY=
# Shown in the dashboard AFTER you save the payment options. Required to verify callbacks.
EASYKASH_HMAC_SECRET=
# Optional: charge a deposit instead of the full starting price (1–100). Default 100.
EASYKASH_DEPOSIT_PERCENT=

# --- Live rates from the elbakri-rate hub (optional; unset = static/Supabase catalog) ---
# e.g. https://your-domain/rates/api  — the public-catalog endpoint token must match.
RATE_API_URL=
RATE_API_PUBLIC_TOKEN=
# Optional cache duration in seconds. Default: 300 (5 minutes).
RATE_API_REVALIDATE=300
